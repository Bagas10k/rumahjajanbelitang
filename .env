# =========================================================================
# KREDENSIAL IPAYMU (MASUKKAN DATA AKUN IPAYMU ANDA DI SINI)
# =========================================================================

# Nomor Virtual Account (VA) Merchant iPaymu Anda
IPAYMU_VA=0000002185504003

# API Key iPaymu Anda (Didapatkan dari menu Integrasi di Dashboard iPaymu)
IPAYMU_API_KEY=SANDBOX1776E990-0C70-478B-8DDB-E7701953AD6E

# Setel ke 'true' untuk mode Sandbox (Testing)
# Setel ke 'false' untuk mode Production (Live)
IPAYMU_IS_SANDBOX=true

# =========================================================================
# KREDENSIAL SUPABASE DATABASE
# =========================================================================

# URL Project Supabase Anda (Buka Dashboard Supabase -> Project Settings -> API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon Public Key (Digunakan aman di frontend browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (PENTING: Hanya diletakkan di backend/Vercel serverless)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
